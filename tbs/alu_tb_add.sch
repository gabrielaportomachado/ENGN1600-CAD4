C {code_shown.sym} 1692.5 -1825 0 0 {name=s1 only_toplevel=false value="
.control
  let vlow = 0
  let vhigh = 3.3

  * ADD mode
  alter VS1 = $&vlow
  alter VS0 = $&vlow

  * Carry in = 0
  alter VCin = $&vlow

  * A = 0x0103 = 259
  alter VA15 = $&vlow
  alter VA14 = $&vlow
  alter VA13 = $&vlow
  alter VA12 = $&vlow
  alter VA11 = $&vlow
  alter VA10 = $&vlow
  alter VA9  = $&vlow
  alter VA8  = $&vhigh
  alter VA7  = $&vlow
  alter VA6  = $&vlow
  alter VA5  = $&vlow
  alter VA4  = $&vlow
  alter VA3  = $&vlow
  alter VA2  = $&vlow
  alter VA1  = $&vhigh
  alter VA0  = $&vhigh

  * B = 0x0005
  alter VB15 = $&vlow
  alter VB14 = $&vlow
  alter VB13 = $&vlow
  alter VB12 = $&vlow
  alter VB11 = $&vlow
  alter VB10 = $&vlow
  alter VB9  = $&vlow
  alter VB8  = $&vlow
  alter VB7  = $&vlow
  alter VB6  = $&vlow
  alter VB5  = $&vlow
  alter VB4  = $&vlow
  alter VB3  = $&vlow
  alter VB2  = $&vhigh
  alter VB1  = $&vlow
  alter VB0  = $&vhigh

  * Solve DC operating point first
  op
display v(y0) v(y1) v(y2)

  * Print only the bits that matter for 3 + 5 = 8
  * Optional very short transient, just for waveform screenshot
  tran 0.1n 30n
print v(y3)[307] v(y2)[307] v(y1)[307] v(y0)[307]
let last = length(v(y0)) - 1

  * --- Digitizing each bit (1 if > 3V, else 0) ---
meas tran v0  find v(y0)  at=30n
  meas tran v1  find v(y1)  at=30n
  meas tran v2  find v(y2)  at=30n
  meas tran v3  find v(y3)  at=30n
  meas tran v4  find v(y4)  at=30n
  meas tran v5  find v(y5)  at=30n
  meas tran v6  find v(y6)  at=30n
  meas tran v7  find v(y7)  at=30n
  meas tran v8  find v(y8)  at=30n
  meas tran v9  find v(y9)  at=30n
  meas tran v10 find v(y10) at=30n
  meas tran v11 find v(y11) at=30n
  meas tran v12 find v(y12) at=30n
  meas tran v13 find v(y13) at=30n
  meas tran v14 find v(y14) at=30n
  meas tran v15 find v(y15) at=30n

  * 2. Initialize our tracking variables
  let decimal_result = 0
  let b0=0 b1=0 b2=0 b3=0 b4=0 b5=0 b6=0 b7=0
  let b8=0 b9=0 b10=0 b11=0 b12=0 b13=0 b14=0 b15=0

  * 3. Logic checks using IF blocks (Standard threshold 1.6V)
  if v0 > 1.6
    let b0 = 1
    let decimal_result = decimal_result + 1
  end
  if v1 > 1.6
    let b1 = 1
    let decimal_result = decimal_result + 2
  end
  if v2 > 1.6
    let b2 = 1
    let decimal_result = decimal_result + 4
  end
  if v3 > 1.6
    let b3 = 1
    let decimal_result = decimal_result + 8
  end
  if v4 > 1.6
    let b4 = 1
    let decimal_result = decimal_result + 16
  end
  if v5 > 1.6
    let b5 = 1
    let decimal_result = decimal_result + 32
  end
  if v6 > 1.6
    let b6 = 1
    let decimal_result = decimal_result + 64
  end
  if v7 > 1.6
    let b7 = 1
    let decimal_result = decimal_result + 128
  end
  if v8 > 1.6
    let b8 = 1
    let decimal_result = decimal_result + 256
  end
  if v9 > 1.6
    let b9 = 1
    let decimal_result = decimal_result + 512
  end
  if v10 > 1.6
    let b10 = 1
    let decimal_result = decimal_result + 1024
  end
  if v11 > 1.6
    let b11 = 1
    let decimal_result = decimal_result + 2048
  end
  if v12 > 1.6
    let b12 = 1
    let decimal_result = decimal_result + 4096
  end
  if v13 > 1.6
    let b13 = 1
    let decimal_result = decimal_result + 8192
  end
  if v14 > 1.6
    let b14 = 1
    let decimal_result = decimal_result + 16384
  end
  if v15 > 1.6
    let b15 = 1
    let decimal_result = decimal_result + 32768
  end
  * --- Calculate Decimal Sum ---
echo adding 5 to 259
print decimal_result 
write alu_add_results.raw
.endc
"}
C {devices/code_shown.sym} 687.5 32.5 0 0 {name=MODELS1 only_toplevel=true
format="tcleval( @value )"
value="
.include $::180MCU_MODELS/design.ngspice
.lib $::180MCU_MODELS/sm141064.ngspice typical
"}
